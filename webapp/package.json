{
  "name": "sillystage-webapp",
  "private": true,
  "version": "0.1.1",
  "description": "Frontend scaffold for SillyStage.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "tsc -b --pretty false",
    "build": "tsc -b && vite build",
